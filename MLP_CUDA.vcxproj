<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================================
  MLP_CUDA.vcxproj  =  Visual Studio (2026 / v180) project for the CUDA MLP.
  ============================================================================
  Open MLP_CUDA.sln in Visual Studio and press F5 (or Ctrl+F5) to build & run
  the guided feature showcase in demo/demo.cu.

  Notes for the curious:
  * This is a NATIVE CUDA project: each .cu file is a <CudaCompile> item, compiled
    by nvcc via the CUDA build customization. The customization is imported from
    $(VCTargetsPath)\BuildCustomizations\CUDA 13.3.{props,targets}, which the CUDA
    13.3 toolkit installs into Visual Studio (confirmed present for VS v180).
  * The project deliberately compiles the library .cu files PLUS demo/demo.cu, but
    NOT src/main.cu — that avoids having two main() functions (src/main.cu is the
    entry point for the Makefile / CMake command-line builds instead).
  * PlatformToolset = $(DefaultPlatformToolset) auto-selects whatever toolset the
    installed Visual Studio provides, so this isn't pinned to one VS version.
  * GPU architecture is sm_75 (Turing, e.g. RTX 20-series). Change CodeGeneration
    below to match your card (sm_86 = Ampere, sm_89 = Ada, ...).
  ============================================================================
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{B7A3F1C2-9D4E-4A6B-8C1D-2E3F4A5B6C7D}</ProjectGuid>
    <RootNamespace>MLP_CUDA</RootNamespace>
    <!-- Installed Windows SDK on this machine; adjust if yours differs. -->
    <WindowsTargetPlatformVersion>10.0.26100.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <!-- $(DefaultPlatformToolset) is defined by Microsoft.Cpp.Default.props above
         and resolves to the installed VS toolset (e.g. VS 2026), so we don't pin
         a specific version here. -->
    <PlatformToolset>$(DefaultPlatformToolset)</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <PlatformToolset>$(DefaultPlatformToolset)</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- Resolve the CUDA toolkit location BEFORE importing the CUDA props (which
       reads CudaToolkitDir). The CUDA installer sets the CUDA_PATH environment
       variable machine-wide and Visual Studio inherits it; we add an explicit
       fallback so the project also builds if CUDA_PATH happens to be unset. -->
  <PropertyGroup>
    <CudaToolkitDir Condition="'$(CudaToolkitDir)'=='' and '$(CUDA_PATH)'!=''">$(CUDA_PATH)\</CudaToolkitDir>
    <CudaToolkitDir Condition="'$(CudaToolkitDir)'==''">C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.3\</CudaToolkitDir>
  </PropertyGroup>

  <!-- Bring in the CUDA build customization (defines how <CudaCompile> items
       are compiled with nvcc). Installed by the CUDA 13.3 toolkit. -->
  <ImportGroup Label="ExtensionSettings">
    <Import Project="$(VCTargetsPath)\BuildCustomizations\CUDA 13.3.props" />
  </ImportGroup>

  <PropertyGroup>
    <OutDir>$(SolutionDir)$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>

  <!-- Debug build settings -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>Disabled</Optimization>
      <!-- include/ holds all the .cuh headers; add it so #include "mlp.cuh" works
           for the host side / IntelliSense. -->
      <AdditionalIncludeDirectories>$(ProjectDir)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
    <CudaCompile>
      <TargetMachinePlatform>64</TargetMachinePlatform>
      <CodeGeneration>compute_75,sm_75</CodeGeneration>
      <!-- Pass include/ to nvcc itself (the .cu files include the headers by
           name). Using -I via AdditionalOptions is robust across CUDA versions. -->
      <AdditionalOptions>-I"$(ProjectDir)include" %(AdditionalOptions)</AdditionalOptions>
    </CudaCompile>
  </ItemDefinitionGroup>

  <!-- Release build settings -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <AdditionalIncludeDirectories>$(ProjectDir)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
    <CudaCompile>
      <TargetMachinePlatform>64</TargetMachinePlatform>
      <CodeGeneration>compute_75,sm_75</CodeGeneration>
      <AdditionalOptions>-I"$(ProjectDir)include" %(AdditionalOptions)</AdditionalOptions>
    </CudaCompile>
  </ItemDefinitionGroup>

  <!-- Headers (for the Solution Explorer + IntelliSense). -->
  <ItemGroup>
    <ClInclude Include="include\common.cuh" />
    <ClInclude Include="include\matrix.cuh" />
    <ClInclude Include="include\kernels.cuh" />
    <ClInclude Include="include\mlp.cuh" />
    <ClInclude Include="include\dataset.cuh" />
    <ClInclude Include="include\optim.cuh" />
  </ItemGroup>

  <!-- CUDA sources: the library .cu files + the demo entry point.
       NOTE: src\main.cu is intentionally EXCLUDED (it has its own main()). -->
  <ItemGroup>
    <CudaCompile Include="src\matrix.cu" />
    <CudaCompile Include="src\kernels.cu" />
    <CudaCompile Include="src\mlp.cu" />
    <CudaCompile Include="src\dataset.cu" />
    <CudaCompile Include="src\optim.cu" />
    <CudaCompile Include="demo\demo.cu" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
    <Import Project="$(VCTargetsPath)\BuildCustomizations\CUDA 13.3.targets" />
  </ImportGroup>
</Project>
